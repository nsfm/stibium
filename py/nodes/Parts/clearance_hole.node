import fab

title('Clearance Hole')

# NEGATIVE: wire into a Difference `b` input.  Plain shaft, drilled DOWN from
# the top face at z_top.  Diameter from the ISO 273 close-fit preset.
input('x', float, 0)
input('y', float, 0)
input('z_top', float, 0)
input('length', float, 10)
input('size', str, 'M3')

output('shape', fab.shapes.clearance_hole(x, y, z_top, length, size))

sb.ui.point(x, y, z_top)
