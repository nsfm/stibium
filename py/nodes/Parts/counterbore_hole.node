import fab

title('Counterbore Hole')

# NEGATIVE: wire into a Difference `b` input.  Clearance shaft + cylindrical
# recess for a socket-head cap screw (DIN 912 / ISO 4762).
input('x', float, 0)
input('y', float, 0)
input('z_top', float, 0)
input('length', float, 12)
input('size', str, 'M3')

output('shape', fab.shapes.counterbore_hole(x, y, z_top, length, size))

sb.ui.point(x, y, z_top)
