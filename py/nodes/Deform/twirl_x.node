import fab
import math

title('Twirl (X)')

input('shape', fab.types.Shape)
input('amount', float, 90)   # degrees at the centre
input('radius', float, 1)    # falloff distance
input('x', float, 0)
input('y', float, 0)
input('z', float, 0)

output('twirled', fab.shapes.twirl_x(shape, amount, radius, x, y, z))

# UI
sb.ui.wireframe([
    (x, math.cos(i/36. * 2*math.pi) * radius + y,
        math.sin(i/36. * 2*math.pi) * radius + z)
    for i in range(36)], close=True)
sb.ui.point(x, y, z)
