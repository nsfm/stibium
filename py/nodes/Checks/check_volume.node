import fab

title('Check: Volume')

input('shape', fab.types.Shape)
input('at_least', float, 0)
input('at_most', float, 1e30)
input('resolution', float, 0)

m = fab.shapes.measure(shape, resolution)
key = 'area' if m['flat'] else 'volume'
v = m[key]
if v < at_least:
    raise RuntimeError("%s %.6g is below the minimum %g" % (key, v, at_least))
if v > at_most:
    raise RuntimeError("%s %.6g is above the maximum %g" % (key, v, at_most))

output('ok', shape)
