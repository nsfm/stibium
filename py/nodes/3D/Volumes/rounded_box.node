import fab

title('Rounded Box (exact SDF)')

input('xmin', float, -1)
input('xmax', float, 1)
input('ymin', float, -1)
input('ymax', float, 1)
input('zmin', float, -1)
input('zmax', float, 1)
input('r', float, 0.25)

output('shape', fab.shapes.rounded_box(xmin, xmax, ymin, ymax,
                                       zmin, zmax, r))

# UI
sb.ui.point(xmin, ymin, zmin)
sb.ui.point(xmax, ymax, zmax)
